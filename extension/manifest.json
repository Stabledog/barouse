{
  "manifest_version": 3,
  "name": "Barouse",
  "version": "2.8.0",
  "description": "Browser-owned sidebar hosting arbitrary sites in iframes",
  "permissions": [
    "sidePanel",
    "tabs",
    "scripting",
    "declarativeNetRequest",
    "webRequest",
    "storage",
    "clipboardRead",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "options_page": "options.html",
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "Toggle Barouse"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "nav-helper.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
